# Remote Windows over PSRP. Copy to inventory_psrp.yml and edit. Do not commit real values.
# Requires: pip install pypsrp   and a reachable WSMan listener on the target.
# Set the password via env var:  $env:WIN_PW = "..."
all:
  children:
    windows:
      hosts:
        win1:
          ansible_host: 203.0.113.20               # <-- your Windows host IP/DNS
          ansible_user: Administrator              # <-- remote user
          ansible_password: "{{ lookup('env', 'WIN_PW') }}"
          ansible_connection: psrp
          ansible_psrp_auth: ntlm
          # HTTPS (port 5986). For a self-signed cert, ignore validation:
          ansible_port: 5986
          ansible_psrp_protocol: https
          ansible_psrp_cert_validation: ignore
          # For plain HTTP instead, use: ansible_port: 5985 / ansible_psrp_protocol: http
          #
          # NOTE: psrp to localhost with a local account over loopback can fail NTLM (a Windows
          # SSPI loopback nuance); real remote hosts work normally.
