# Remote Windows over WinRM. Copy to inventory_winrm.yml and edit. Do not commit real values.
# Requires: pip install pywinrm   and a reachable WSMan listener on the target.
# Set the password via env var:  $env:WIN_PW = "..."
all:
  children:
    windows:
      hosts:
        win1:
          ansible_host: 203.0.113.20               # <-- your Windows host IP/DNS
          ansible_user: Administrator              # <-- remote user
          ansible_password: "{{ lookup('env', 'WIN_PW') }}"
          ansible_connection: winrm
          ansible_winrm_transport: ntlm
          # HTTPS (port 5986). For a self-signed cert, ignore validation:
          ansible_port: 5986
          ansible_winrm_scheme: https
          ansible_winrm_server_cert_validation: ignore
          # For plain HTTP instead, use: ansible_port: 5985 / ansible_winrm_scheme: http
